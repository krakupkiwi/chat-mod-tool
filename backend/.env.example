# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Twitch application Client ID (from dev.twitch.tv/console/apps)
# You can also set this through the UI on first run.
TWITCHIDS_CLIENT_ID=your_client_id_here

# Channel to monitor on startup (optional — can be set in UI)
TWITCHIDS_DEFAULT_CHANNEL=

# Development mode — bypasses Electron IPC protocol, emits ready immediately
# Set to true when running backend standalone without Electron
TWITCHIDS_DEV=false

# Safety: keep dry_run=true until you've verified detection accuracy
TWITCHIDS_DRY_RUN=true

# Server port (Electron will override this via --port arg)
TWITCHIDS_PORT=7842

# Simulator injection endpoint — ONLY for development/testing.
# Requires TWITCHIDS_DEV=true. The backend will refuse to start if this is
# true without dev mode — it must NEVER be set in a production install.
# TWITCHIDS_SIMULATOR_ACTIVE=false
